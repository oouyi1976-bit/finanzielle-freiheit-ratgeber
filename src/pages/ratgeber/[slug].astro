---
import CTABox from "@components/CTABox.astro";
import Disclaimer from "@components/Disclaimer.astro";
import DisclaimerBox from "@components/DisclaimerBox.astro";
import RelatedArticles from "@components/RelatedArticles.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { dogArticleLinks } from "../../data/dogContent";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const slug = post.id.replace(/\.md$/, "");
const isDogArticle = post.data.category.startsWith("Hunde");
const relatedDogArticles = dogArticleLinks.filter((item) => item.href !== `/ratgeber/${slug}`).slice(0, 3);
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  inLanguage: "de-DE"
};
---

<BaseLayout title={post.data.title} description={post.data.description} canonical={`/ratgeber/${slug}`}>
  <article class="mx-auto max-w-3xl px-4 py-14 sm:px-6 lg:px-8">
    <p class="text-sm font-extrabold uppercase text-gold-600">{post.data.category} · {post.data.readingTime}</p>
    <h1 class="mt-3 text-4xl font-black leading-tight text-navy-900 sm:text-5xl">{post.data.title}</h1>
    <p class="mt-5 text-lg leading-8 text-slate-600">{post.data.description}</p>
    <div class="mt-10 content-prose">
      <Content />
    </div>
    <div class="mt-12">
      {isDogArticle ? <DisclaimerBox variant={post.data.category.includes("Pflege") || post.data.category.includes("Futter") ? "health" : "general"} /> : <Disclaimer />}
    </div>
    <div class="mt-8">
      {
        isDogArticle ? (
          <CTABox
            title="Weiter im Hundebereich"
            text="Wenn du passende Produktideen oder weitere Ratgeber suchst, findest du im Hundebereich strukturierte Übersichten mit Affiliate-Hinweis."
            label="Hundeprodukte ansehen"
            href="/beste-hundeprodukte"
          />
        ) : (
          <CTABox title="Passendes Finanzbuch ansehen" text="Wenn du die Grundlagen zusammenhängend lesen möchtest, kann das Buch ein sinnvoller Einstieg sein. Prüfe vor der Bestellung alle Konditionen." />
        )
      }
    </div>
  </article>
  {
    isDogArticle && (
      <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6 lg:px-8">
        <RelatedArticles items={relatedDogArticles} title="Weitere Hunde-Ratgeber" />
      </section>
    )
  }
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleJsonLd)} />
</BaseLayout>
