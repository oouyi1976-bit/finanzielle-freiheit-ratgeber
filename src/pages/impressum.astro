---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Impressum"
  description="Impressum der Affiliate-Website. Platzhalter bitte vor Veröffentlichung mit den korrekten Angaben ersetzen."
  canonical="/impressum"
  noindex={true}
>
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-black text-navy-900">Impressum</h1>
    <div class="content-prose mt-8">
      <p><strong>Platzhalter:</strong> Bitte vor Veröffentlichung vollständig mit deinen rechtlich korrekten Angaben ersetzen.</p>
      <h2>Angaben gemäß § 5 TMG</h2>
      <p>
        Max Mustermann<br />
        Musterstraße 1<br />
        12345 Musterstadt<br />
        Deutschland
      </p>
      <h2>Kontakt</h2>
      <p>
        Telefon: +49 000 000000<br />
        E-Mail: kontakt@example.com
      </p>
      <h2>Verantwortlich für den Inhalt</h2>
      <p>
        Max Mustermann<br />
        Musterstraße 1<br />
        12345 Musterstadt
      </p>
      <h2>Hinweis</h2>
      <p>
        Dies ist ein Platzhalter-Impressum und keine Rechtsberatung. Prüfe vor dem Livegang, welche Angaben für deine konkrete Website erforderlich sind.
      </p>
    </div>
  </section>
</BaseLayout>
