---
interface Props {
  pros?: string[];
  cons?: string[];
}

const {
  pros = [
    "Verstaendlicher Einstieg in Geldgrundlagen",
    "Motiviert zu klaren Zielen und festen Routinen",
    "Geeignet fuer Leser, die ihre Finanzen aktiv ordnen wollen"
  ],
  cons = [
    "Keine persoenliche Anlageberatung",
    "Erfordert eigene Umsetzung ueber laengere Zeit",
    "Nicht jede Empfehlung passt zu jeder Lebenssituation"
  ]
} = Astro.props;
---

<section class="grid gap-4 md:grid-cols-2">
  <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-6">
    <h2 class="text-xl font-black text-emerald-950">Pro</h2>
    <ul class="mt-4 grid gap-3 text-sm leading-6 text-emerald-950">
      {pros.map((item) => <li class="flex gap-3"><span aria-hidden="true">+</span><span>{item}</span></li>)}
    </ul>
  </div>
  <div class="rounded-lg border border-slate-200 bg-slate-50 p-6">
    <h2 class="text-xl font-black text-navy-900">Contra</h2>
    <ul class="mt-4 grid gap-3 text-sm leading-6 text-slate-700">
      {cons.map((item) => <li class="flex gap-3"><span aria-hidden="true">-</span><span>{item}</span></li>)}
    </ul>
  </div>
</section>
