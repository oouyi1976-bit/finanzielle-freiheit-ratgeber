---

<section class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-soft">
  <div class="border-b border-slate-200 p-6">
    <p class="text-sm font-extrabold uppercase text-gold-600">Vergleich</p>
    <h2 class="mt-2 text-2xl font-black text-navy-900">Welche Art von Finanzhilfe passt?</h2>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full min-w-[720px] border-collapse text-left text-sm">
      <thead class="bg-slate-50 text-navy-900">
        <tr>
          <th class="border-b border-slate-200 px-6 py-4 font-black">Option</th>
          <th class="border-b border-slate-200 px-6 py-4 font-black">Staerke</th>
          <th class="border-b border-slate-200 px-6 py-4 font-black">Grenze</th>
          <th class="border-b border-slate-200 px-6 py-4 font-black">Geeignet fuer</th>
        </tr>
      </thead>
      <tbody class="text-slate-700">
        <tr>
          <td class="border-b border-slate-100 px-6 py-4 font-extrabold text-navy-900">Der Weg zur finanziellen Freiheit</td>
          <td class="border-b border-slate-100 px-6 py-4">Motivation, Grundprinzipien und Geld-Mindset</td>
          <td class="border-b border-slate-100 px-6 py-4">Keine individuelle Strategie</td>
          <td class="border-b border-slate-100 px-6 py-4">Einsteiger, Familien, Selbststaendige</td>
        </tr>
        <tr>
          <td class="border-b border-slate-100 px-6 py-4 font-extrabold text-navy-900">Haushaltsbuch und Budgetplan</td>
          <td class="border-b border-slate-100 px-6 py-4">Schneller Ueberblick ueber Einnahmen und Ausgaben</td>
          <td class="border-b border-slate-100 px-6 py-4">Loest keine strukturellen Einkommens- oder Schuldenprobleme allein</td>
          <td class="border-b border-slate-100 px-6 py-4">Alle, die Ordnung schaffen wollen</td>
        </tr>
        <tr>
          <td class="px-6 py-4 font-extrabold text-navy-900">Professionelle Beratung</td>
          <td class="px-6 py-4">Individuelle Betrachtung der persoenlichen Situation</td>
          <td class="px-6 py-4">Kann Kosten verursachen und muss sorgfaeltig ausgewaehlt werden</td>
          <td class="px-6 py-4">Komplexe Fragen, Schulden, Steuern, Vorsorge</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>
