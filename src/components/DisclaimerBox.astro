---
interface Props {
  variant?: "health" | "affiliate" | "general";
}

const { variant = "general" } = Astro.props;
const text = {
  general:
    "Diese Inhalte sind allgemeine Ratgeberinformationen für Hundebesitzer. Sie ersetzen keine individuelle Einschätzung durch Hundeschule, Trainer, Tierarzt oder Tierärztin.",
  health:
    "Gesundheitliche Hinweise auf dieser Website ersetzen keine Tierarztberatung. Bei Schmerzen, Lahmheit, starkem Juckreiz, Durchfall, Erbrechen, Atemproblemen oder verändertem Verhalten solltest du zeitnah eine Tierarztpraxis kontaktieren.",
  affiliate:
    "Diese Website nutzt Affiliate-Links. Bei einem Kauf über solche Links kann eine Provision entstehen; für dich bleibt der Preis in der Regel gleich. Empfehlungen werden redaktionell eingeordnet und ohne Erfolgsgarantien formuliert."
}[variant];
---

<aside class="rounded-lg border border-amber-200 bg-amber-50 p-5 text-sm leading-7 text-amber-950">
  <strong>Hinweis:</strong> {text}
</aside>
