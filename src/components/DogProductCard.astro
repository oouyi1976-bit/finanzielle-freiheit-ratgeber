---
import AffiliateButton from "@components/AffiliateButton.astro";
import type { DogProduct } from "../data/dogProducts";

interface Props {
  product: DogProduct;
}

const { product } = Astro.props;
---

<article class="flex h-full flex-col rounded-lg border border-slate-200 bg-white p-5 shadow-soft">
  <div class="rounded-md bg-slate-50 p-4">
    <p class="text-xs font-extrabold uppercase text-gold-600">{product.category}</p>
    <h3 class="mt-2 text-xl font-black leading-snug text-navy-900">{product.name}</h3>
    <p class="mt-3 text-sm leading-7 text-slate-600">{product.shortDescription}</p>
  </div>

  <div class="mt-5 grid flex-1 gap-4 text-sm leading-6 text-slate-700">
    <div>
      <p class="font-extrabold text-navy-900">Vorteile</p>
      <ul class="mt-2 grid gap-2">
        {product.benefits.map((benefit) => <li class="flex gap-2"><span aria-hidden="true">+</span><span>{benefit}</span></li>)}
      </ul>
    </div>
    <p><strong class="text-navy-900">Am besten für:</strong> {product.bestFor}</p>
    <p><strong class="text-navy-900">Preisrahmen:</strong> {product.priceRange}</p>
    <p class="text-xs leading-5 text-slate-500">{product.ratingText}</p>
  </div>

  <div class="mt-5">
    <AffiliateButton href={product.affiliateUrl} label="Bei Amazon ansehen" />
  </div>
</article>
