---
import AffiliateButton from "@components/AffiliateButton.astro";
import type { DigistoreRecommendation } from "../data/dogAffiliateLinks";

interface Props {
  items: DigistoreRecommendation[];
  title?: string;
  text?: string;
}

const {
  items,
  title = "Digitale Hundekurse und Empfehlungen",
  text = "Diese Links wurden inhaltlich geprüft und werden nur dort eingebunden, wo sie zum Hundethema passen."
} = Astro.props;
---

<section class="rounded-lg border border-slate-200 bg-white p-6 shadow-soft">
  <div class="max-w-3xl">
    <p class="text-sm font-extrabold uppercase text-gold-600">Digistore24</p>
    <h2 class="mt-2 text-2xl font-black text-navy-900">{title}</h2>
    <p class="mt-3 leading-7 text-slate-600">{text}</p>
  </div>
  <div class="mt-6 grid gap-4 md:grid-cols-2">
    {
      items.map((item) => (
        <article class:list={[
          "rounded-lg border p-5",
          item.fit === "hund" ? "border-emerald-200 bg-emerald-50" : "border-amber-200 bg-amber-50"
        ]}>
          <p class="text-xs font-extrabold uppercase text-slate-600">{item.category}</p>
          <h3 class="mt-2 text-lg font-black text-navy-900">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-700">{item.description}</p>
          <p class="mt-3 text-sm leading-6 text-slate-700"><strong>Geeignet für:</strong> {item.bestFor}</p>
          <p class="mt-3 text-xs leading-5 text-slate-500">{item.internalNote}</p>
          <div class="mt-5">
            <AffiliateButton href={item.href} label="Angebot ansehen" tone={item.fit === "hund" ? "dark" : "light"} />
          </div>
        </article>
      ))
    }
  </div>
</section>
