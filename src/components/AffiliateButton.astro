---
interface Props {
  href: string;
  label?: string;
  tone?: "dark" | "gold" | "light";
}

const { href, label = "Affiliate-Link öffnen", tone = "dark" } = Astro.props;
const isPlaceholder = href === "AMAZON_AFFILIATE_LINK_HIER_EINFUEGEN" || href === "DIGISTORE24_PROMOLINK_HIER_EINFUEGEN";
const classes = [
  "inline-flex w-full items-center justify-center rounded-md px-4 py-3 text-sm font-extrabold transition",
  tone === "gold" && "bg-gold-500 text-navy-900 hover:bg-gold-300",
  tone === "light" && "border border-slate-300 bg-white text-navy-900 hover:border-gold-500 hover:bg-gold-100",
  tone === "dark" && "bg-navy-900 text-white hover:bg-navy-800",
  isPlaceholder && "cursor-not-allowed opacity-70"
].filter(Boolean).join(" ");
---

{
  isPlaceholder ? (
    <span class={classes} aria-disabled="true">Link noch eintragen</span>
  ) : (
    <a href={href} rel="sponsored nofollow noopener" class={classes}>{label}</a>
  )
}
