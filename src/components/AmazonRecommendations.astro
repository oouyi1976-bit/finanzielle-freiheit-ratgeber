---
import { amazonRecommendations } from "@lib/amazon";

interface Props {
  title?: string;
  text?: string;
  group?: string;
  limit?: number;
  variant?: "light" | "band";
}

const {
  title = "Passende Empfehlungen bei Amazon",
  text = "Ausgewählte Bücher und praktische Hilfsmittel, die thematisch zu Finanzen ordnen, Geld sparen und Vermögen aufbauen passen.",
  group = "all",
  limit = 4,
  variant = "light"
} = Astro.props;

const items = amazonRecommendations.filter((item) => item.groups.includes(group)).slice(0, limit);
const wrapperClass = variant === "band" ? "bg-slate-50 py-14" : "";
---

<section class={wrapperClass || "rounded-lg border border-slate-200 bg-white p-6 shadow-soft"}>
  <div class:list={[variant === "band" && "mx-auto max-w-6xl px-4 sm:px-6 lg:px-8"]}>
    <div class="max-w-2xl">
      <p class="text-sm font-extrabold uppercase text-gold-600">Amazon PartnerNet</p>
      <h2 class="mt-2 text-3xl font-black text-navy-900">{title}</h2>
      <p class="mt-4 leading-7 text-slate-600">{text}</p>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {
        items.map((item) => (
          <article class="flex h-full flex-col rounded-lg border border-slate-200 bg-white p-5 shadow-soft">
            <p class="text-xs font-extrabold uppercase text-gold-600">{item.category}</p>
            <h3 class="mt-2 text-lg font-black leading-snug text-navy-900">{item.title}</h3>
            <p class="mt-1 text-sm font-bold text-slate-500">{item.author}</p>
            <p class="mt-3 flex-1 text-sm leading-7 text-slate-600">{item.description}</p>
            <a
              href={item.href}
              rel="sponsored nofollow noopener"
              class="mt-5 inline-flex items-center justify-center rounded-md bg-navy-900 px-4 py-3 text-sm font-extrabold text-white transition hover:bg-navy-800"
            >
              Bei Amazon ansehen
            </a>
          </article>
        ))
      }
    </div>
    <p class="mt-5 text-xs leading-6 text-slate-500">
      Als Amazon-Partner verdiene ich an qualifizierten Verkäufen. Preise und Verfügbarkeit werden auf Amazon.de angezeigt.
    </p>
  </div>
</section>
