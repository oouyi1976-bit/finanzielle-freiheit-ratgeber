---
import { footerLinks, navLinks, SITE } from "@lib/site";
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:px-6 md:grid-cols-[1.2fr_1fr_1fr] lg:px-8">
    <div>
      <p class="text-lg font-extrabold text-navy-900">{SITE.name}</p>
      <p class="mt-3 max-w-md text-sm leading-7 text-slate-600">
        Ruhige Orientierung fuer Menschen, die ihre Finanzen ordnen, bewusster sparen und den Vermoegensaufbau besser verstehen moechten.
      </p>
    </div>
    <div>
      <p class="font-extrabold text-navy-900">Themen</p>
      <div class="mt-3 grid gap-2 text-sm text-slate-600">
        {navLinks.slice(1).map((link) => <a class="hover:text-navy-900" href={link.href}>{link.label}</a>)}
      </div>
    </div>
    <div>
      <p class="font-extrabold text-navy-900">Rechtliches</p>
      <div class="mt-3 grid gap-2 text-sm text-slate-600">
        {footerLinks.map((link) => <a class="hover:text-navy-900" href={link.href}>{link.label}</a>)}
      </div>
    </div>
  </div>
  <div class="border-t border-slate-200 px-4 py-4 text-center text-xs text-slate-500">
    © {new Date().getFullYear()} {SITE.name}. Keine Finanzberatung, keine Erfolgsgarantie.
  </div>
</footer>
