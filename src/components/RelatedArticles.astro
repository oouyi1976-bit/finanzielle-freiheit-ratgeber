---
import type { RelatedItem } from "../data/dogContent";
import ArticleCard from "@components/ArticleCard.astro";

interface Props {
  items: RelatedItem[];
  title?: string;
  text?: string;
}

const { items, title = "Weiterlesen", text } = Astro.props;
---

<section>
  <div class="max-w-3xl">
    <p class="text-sm font-extrabold uppercase text-gold-600">Interne Links</p>
    <h2 class="mt-2 text-3xl font-black text-navy-900">{title}</h2>
    {text && <p class="mt-4 leading-7 text-slate-600">{text}</p>}
  </div>
  <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {items.map((item) => <ArticleCard title={item.title} description={item.description} href={item.href} meta={item.meta} />)}
  </div>
</section>
