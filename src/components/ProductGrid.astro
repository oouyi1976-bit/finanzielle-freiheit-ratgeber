---
import DogProductCard from "@components/DogProductCard.astro";
import type { DogProduct } from "../data/dogProducts";

interface Props {
  products: DogProduct[];
  title?: string;
  text?: string;
  limit?: number;
}

const { products, title = "Passende Hundeprodukte", text, limit } = Astro.props;
const visibleProducts = typeof limit === "number" ? products.slice(0, limit) : products;
---

<section>
  <div class="max-w-3xl">
    <p class="text-sm font-extrabold uppercase text-gold-600">Amazon PartnerNet</p>
    <h2 class="mt-2 text-3xl font-black text-navy-900">{title}</h2>
    {text && <p class="mt-4 leading-7 text-slate-600">{text}</p>}
  </div>
  <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
    {visibleProducts.map((product) => <DogProductCard product={product} />)}
  </div>
  <p class="mt-5 text-xs leading-6 text-slate-500">
    Als Amazon-Partner verdiene ich an qualifizierten Verkäufen. Aktuell sind Platzhalterlinks hinterlegt; echte Amazon-Links sollten später mit Tracking-ID eingetragen und geprüft werden.
  </p>
</section>
