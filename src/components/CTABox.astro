---
import { PROMO_LINK } from "@lib/site";

interface Props {
  title?: string;
  text?: string;
  label?: string;
  href?: string;
}

const {
  title = "Möchtest du das Buch prüfen?",
  text = "Wenn du deine Finanzen geordneter angehen möchtest, kann das Buch ein ruhiger Einstieg sein. Prüfe die Konditionen im Bestellprozess und entscheide ohne Druck.",
  label = "Zum kostenlosen Buch",
  href = PROMO_LINK
} = Astro.props;
---

<section class="rounded-lg bg-navy-900 p-6 text-white shadow-soft sm:p-8">
  <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
    <div>
      <h2 class="text-2xl font-black">{title}</h2>
      <p class="mt-3 max-w-2xl leading-7 text-slate-200">{text}</p>
    </div>
    <a
      href={href}
      rel="sponsored nofollow noopener"
      class="inline-flex items-center justify-center rounded-md bg-gold-500 px-5 py-3 text-sm font-black text-navy-900 transition hover:bg-gold-300"
    >
      {label}
    </a>
  </div>
</section>
