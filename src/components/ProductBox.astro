---
import { PROMO_LINK } from "@lib/site";

interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Der Weg zur finanziellen Freiheit",
  text = "Das gedruckte Finanzbuch von Bodo Schäfer richtet sich an Menschen, die Geldthemen strukturierter angehen und langfristig bewusster entscheiden möchten."
} = Astro.props;
---

<aside class="rounded-lg border border-slate-200 bg-white p-6 shadow-soft">
  <p class="text-sm font-extrabold uppercase text-gold-600">Buch-Empfehlung</p>
  <h2 class="mt-2 text-2xl font-black text-navy-900">{title}</h2>
  <p class="mt-3 leading-7 text-slate-600">{text}</p>
  <ul class="mt-5 grid gap-2 text-sm text-slate-700">
    <li>Gedrucktes Finanzbuch fuer Einsteiger und Umsetzer</li>
    <li>Fokus auf Geldbewusstsein, Sparquote und langfristige Ziele</li>
    <li>Bestellung ueber Digistore24 nach Pruefung der Konditionen</li>
  </ul>
  <a
    href={PROMO_LINK}
    rel="sponsored nofollow noopener"
    class="mt-6 inline-flex w-full items-center justify-center rounded-md bg-gold-500 px-5 py-3 text-sm font-black text-navy-900 transition hover:bg-gold-300"
  >
    Zum kostenlosen Buch
  </a>
  <p class="mt-3 text-xs leading-5 text-slate-500">
    Hinweis: Der Promolink ist als Platzhalter hinterlegt. Bitte pruefe im Bestellprozess Preis, Versand, Zahlungsbedingungen und Widerruf.
  </p>
</aside>
