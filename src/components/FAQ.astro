---
import { defaultFaq } from "@lib/site";

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FaqItem[];
  title?: string;
}

const { items = defaultFaq, title = "Häufige Fragen" } = Astro.props;
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};
---

<section class="rounded-lg border border-slate-200 bg-white p-6 shadow-soft">
  <h2 class="text-2xl font-black text-navy-900">{title}</h2>
  <div class="mt-5 grid gap-3">
    {
      items.map((item) => (
        <details class="group rounded-md border border-slate-200 bg-slate-50 p-4">
          <summary class="cursor-pointer list-none font-extrabold text-navy-900">{item.question}</summary>
          <p class="mt-3 leading-7 text-slate-600">{item.answer}</p>
        </details>
      ))
    }
  </div>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />
</section>
