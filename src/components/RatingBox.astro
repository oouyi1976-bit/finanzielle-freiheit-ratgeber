---
interface Props {
  score?: string;
  title?: string;
  text?: string;
}

const {
  score = "4,5 / 5",
  title = "Redaktionelle Einschätzung",
  text = "Stark fuer Motivation, Geldbewusstsein und klare Routinen. Die Inhalte sollten mit eigener Recherche und, bei Bedarf, professioneller Beratung kombiniert werden."
} = Astro.props;
---

<section class="rounded-lg border border-slate-200 bg-white p-6 shadow-soft">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-extrabold uppercase text-gold-600">{title}</p>
      <h2 class="mt-2 text-3xl font-black text-navy-900">{score}</h2>
    </div>
    <div class="flex gap-1 text-2xl text-gold-500" aria-label="Redaktionelle Bewertung 4,5 von 5">
      <span>★</span><span>★</span><span>★</span><span>★</span><span>☆</span>
    </div>
  </div>
  <p class="mt-4 leading-7 text-slate-600">{text}</p>
  <p class="mt-3 text-xs leading-5 text-slate-500">
    Dies ist eine redaktionelle Einordnung, keine verifizierte Kundenbewertung und keine Anlageempfehlung.
  </p>
</section>
