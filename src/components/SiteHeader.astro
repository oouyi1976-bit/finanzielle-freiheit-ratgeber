---
import { navLinks } from "@lib/site";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  return normalized === "/" ? currentPath === "/" : currentPath.startsWith(normalized);
};
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3 font-extrabold text-navy-900" aria-label="Startseite">
      <span class="grid h-9 w-9 place-items-center rounded-md bg-navy-900 text-sm font-black text-gold-300">FF</span>
      <span class="leading-tight">
        <span class="block">Finanzielle</span>
        <span class="block text-sm font-bold text-navy-700">Freiheit Klar</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Hauptnavigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "rounded-md px-3 py-2 text-sm font-bold transition",
              isActive(link.href)
                ? "bg-navy-50 text-navy-900"
                : "text-slate-700 hover:bg-slate-100 hover:text-navy-900"
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <details class="relative md:hidden">
      <summary class="cursor-pointer list-none rounded-md border border-slate-300 px-3 py-2 text-sm font-bold text-navy-900">
        Menü
      </summary>
      <nav class="absolute right-0 mt-2 w-64 rounded-md border border-slate-200 bg-white p-2 shadow-soft" aria-label="Mobile Navigation">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "block rounded-md px-3 py-2 text-sm font-bold",
                isActive(link.href) ? "bg-navy-50 text-navy-900" : "text-slate-700 hover:bg-slate-100"
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>
