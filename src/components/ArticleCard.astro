---
interface Props {
  title: string;
  description: string;
  href: string;
  meta?: string;
}

const { title, description, href, meta } = Astro.props;
---

<article class="rounded-lg border border-slate-200 bg-white p-5 shadow-soft transition hover:-translate-y-0.5 hover:border-gold-300">
  {meta && <p class="text-xs font-extrabold uppercase text-gold-600">{meta}</p>}
  <h3 class="mt-2 text-xl font-black leading-snug text-navy-900">
    <a href={href}>{title}</a>
  </h3>
  <p class="mt-3 text-sm leading-7 text-slate-600">{description}</p>
  <a href={href} class="mt-4 inline-flex text-sm font-extrabold text-navy-900 underline decoration-gold-300 decoration-2 underline-offset-4">
    Weiterlesen
  </a>
</article>
